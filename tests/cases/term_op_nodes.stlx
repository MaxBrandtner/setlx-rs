x:=parse("x");

// defined for both sides
print(x + 1);
print(1 + x);
print(x - 1);
print(1 - x);
print(x * 1);
print(1 * x);
print(x / 1);
print(1 / x);
print(x % 1);
print(1 % x);
print(1 ** x);
print(x ** 1);
print(x><1);
print(1><x);
print(x<==>1);
print(1<==>x);
print(x<!=>1);
print(1<!=>x);

// defined for lhs
print(x => 1);
print(x || 1);
print(x && 1);

// unary
print(-x);
print(!x);
print(x!);
print(#x);
